Section "Module"
	Load "altsec"

	SubSection "altsec"
	    # A list of clients that should be considered trusted when
	    # started after secured phase.
	    Option "TrustedClients" "dmenu:xkill:xrandr:xsetroot:/usr/lib64/misc/ssh-askpass"
	    # Increase log level
	    Option "LogLevel" "1"
	EndSubSection
EndSection
